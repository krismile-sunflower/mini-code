{
  "name": "mini-code-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A small clean-room TypeScript coding agent inspired by public terminal coding harness patterns.",
  "bin": {
    "mini-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^18.3.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
